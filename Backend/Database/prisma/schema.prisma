// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RolUsuario {
  Administrador
  Profesor
  Ayudante
  Estudiante
}

enum BloqueHorario {
  A 
  B  
  C  
  D  
  E 
  F 
}

model Usuario { 
  id    Int     @id @default(autoincrement()) 
  nombre    String
  apellido  String
  rut       String     @unique
  correo    String     @unique
  password  String
  rol       RolUsuario @default(ESTUDIANTE)

  talleresDictados Taller[]      @relation("ProfesorTaller")
  inscripciones    Inscripcion[]
  asistencias      Asistencia[]
} 

model Taller {
  id          Int     @id @default(autoincrement())
  nombre      String
  descripcion String  @db.Text
  horario     String
  semestre    String
  estado      Boolean @default(true)

  profesorId    Int
  profesor      Usuario       @relation("ProfesorTaller", fields: [profesorId], references: [id])
  inscripciones Inscripcion[]
  sesiones      Sesion[]
}

model Inscripcion {
  id            Int      @id @default(autoincrement())
  fechaRegistro DateTime @default(now())

  estudianteId Int
  estudiante   Usuario @relation(fields: [estudianteId], references: [id])
  tallerId     Int
  taller       Taller  @relation(fields: [tallerId], references: [id])

  @@unique([estudianteId, tallerId]) 
}

model Sesion {
  id           Int           @id @default(autoincrement())
  tallerId     Int
  taller       Taller        @relation(fields: [tallerId], references: [id])
  fecha        DateTime      @default(now()) @db.Date
  bloque       BloqueHorario
  
  qrToken      String        @unique
  validoHasta  DateTime      
  
  asistencias  Asistencia[]
}

model Asistencia {
  id               Int      @id @default(autoincrement())
  sesionId         Int
  sesion           Sesion   @relation(fields: [sesionId], references: [id])
  estudianteId     Int
  estudiante       Usuario  @relation(fields: [estudianteId], references: [id])
  notaSatisfaccion Int?   

  fechaHora        DateTime @default(now())
  estado           String   @default("Ausente") 
  notaSatisfaccion Int?     

  @@unique([sesionId, estudianteId])
}